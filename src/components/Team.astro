---
import { getI18N } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
const team = i18n.team

const memberPhotos = [
  'https://images.squarespace-cdn.com/content/v1/65f49327dd654d3f9576e5a1/52941c00-9e0c-4194-9933-6fe29133cdca/Maria+Duffo?format=500w',
  'https://images.squarespace-cdn.com/content/v1/65f49327dd654d3f9576e5a1/839cfe4d-de8c-4f0a-b331-e8c1c2322e2e/Beatriz+Daud%C3%A9n?format=500w',
]
---

<div class="py-24 px-6 bg-slate-50">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <span class="text-primary font-bold tracking-widest uppercase text-xs">{team.badge}</span>
      <h2 class="text-4xl font-bold mt-2 mb-4">{team.title}</h2>
      <p class="text-slate-600 max-w-2xl mx-auto">
        {team.description}
      </p>
    </div>
    <div class="grid lg:grid-cols-2 gap-8">
      {
        team.members.map((member, index) => (
          <div class="bg-white p-6 rounded-3xl shadow-sm border border-accent/20 flex flex-col md:flex-row gap-8 items-start hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 hover:-translate-y-1">
            <div class="shrink-0 w-full md:w-48 lg:w-40 xl:w-48">
              <img
                alt={member.imageAlt}
                class="w-full aspect-4/5 object-cover rounded-2xl shadow-lg border-2 border-white"
                src={memberPhotos[index]}
              />
            </div>
            <div class="flex-1 space-y-4">
              <div>
                <h3 class="text-2xl font-bold text-slate-900">{member.name}</h3>
                <p class="text-primary font-semibold text-sm">{member.role}</p>
              </div>
              <p class="text-slate-600 text-sm leading-relaxed italic border-l-2 border-primary/20 pl-4">
                {member.quote}
              </p>
              <div class="space-y-3">
                <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center gap-2">
                  <span class="material-symbols-outlined text-secondary text-base">verified</span>
                  {team.trajectoryLabel}
                </h4>
                <ul class="space-y-2 text-sm">
                  {member.experience.map((item) => (
                    <li class="flex gap-3">
                      <span class="material-symbols-outlined text-secondary text-sm mt-0.5">
                        check_circle
                      </span>
                      <span class="text-slate-600">{item}</span>
                    </li>
                  ))}
                  <li class="flex gap-3">
                    <span class="material-symbols-outlined text-secondary text-sm mt-0.5">
                      check_circle
                    </span>
                    <span class="text-slate-600">
                      <a
                        class="text-primary"
                        target="_blank"
                        rel="noopener noreferrer"
                        href="https://www.esdm.co/esdm-therapists"
                      >
                        {member.certificateLinkLabel}
                      </a>{' '}
                      {member.certificateSuffix}
                    </span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
