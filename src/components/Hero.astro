---
import { getI18N } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
---

<section class="pt-20 pb-24 px-6 lg:pb-28 bg-background-light">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-12 items-center">
    <div class="space-y-8">
      <div
        class="inline-flex items-center px-3 gap-2 py-1 rounded-full bg-secondary/10 border border-secondary/20 text-secondary text-sm font-semibold tracking-wide uppercase"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-secondary opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-secondary"></span>
        </span>
        {i18n.hero.badge}
      </div>
      <h1
        class="text-4xl lg:text-7xl max-w-3xl lg:max-w-4xl font-extrabold tracking-tight leading-[1.1] text-accent text-pretty md:text-balance"
      >
        {i18n.hero.titlePrefix}
        <span class="text-primary">{i18n.hero.titleHighlight}</span>
        {` ${i18n.hero.titleSuffix}`}
      </h1>
      <p class="text-lg text-slate-600 max-w-xl leading-relaxed">
        {i18n.hero.description}
      </p>
    </div>

    <div
      class="relative rounded-[3rem] overflow-hidden shadow-2xl h-3/4 aspect-square animate-brain place-self-center lg:place-self-end"
    >
      <img
        alt={i18n.hero.imageAlt}
        class="aspect-square object-cover"
        src="https://images.squarespace-cdn.com/content/v1/65f49327dd654d3f9576e5a1/d7c28ffe-2310-40f8-b9af-d877b4f32889/ChatGPT+Image+9+jun+2025%2C+18_30_48.png?format=500w"
      />
    </div>
  </div>
</section>
