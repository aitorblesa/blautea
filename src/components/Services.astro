---
import { getI18N } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
const services = i18n.services
---

<div class="py-24 bg-slate-50 flex flex-col gap-20 px-6">
  <div class="grid md:grid-cols-2 lg:grid-cols-6 md:gap-16 items-center max-w-7xl mx-auto">
    <div class="space-y-8 lg:col-span-3">
      <div
        class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-secondary/10 border border-secondary/20"
      >
        <span class="w-2 h-2 rounded-full bg-secondary"></span>
        <span class="text-secondary text-sm font-semibold tracking-wide uppercase"
          >{services.badge}</span
        >
      </div>
      <h1 class="text-5xl lg:text-7xl font-black leading-[1.1] tracking-[-0.04em] text-slate-900">
        {services.title}
      </h1>
      <div>
        <p class="text-xl lg:max-w-full text-slate-500 leading-relaxed text-balance">
          {services.intro1Prefix}
          <em>{services.intro1Emphasis}</em>
          {services.intro1Suffix}
        </p>

        <p class="mt-2 text-balance text-xl text-slate-500 max-w-xl lg:max-w-full leading-relaxed">
          {services.intro2}<span class="text-primary font-bold">{services.languages}</span>.
        </p>
      </div>
    </div>
    <div
      class="relative rounded-3xl overflow-hidden aspect-square shadow-2xl border border-white/10 flex items-center justify-center p-6 h-3/4 w-full lg:h-4/5 lg:col-span-3"
    >
      <img
        alt={services.imageAlt}
        class="w-full h-full object-cover filter drop-shadow-[0_0_30px_rgba(19,164,236,0.3)] rounded-2xl"
        src="/serveis.webp"
      />
    </div>
  </div>

  <div class="grid lg:grid-cols-6 gap-12 max-w-7xl lg:mx-auto lg:items-center">
    <div class="col-span-3 flex flex-col">
      <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-6 text-slate-900">
        {services.assessmentTitle}
      </h2>
      <p class="text-slate-500 text-lg max-w-md leading-relaxed">
        {services.assessmentDescription}
      </p>
      <div class="mt-8 flex items-center gap-4 text-primary">
        <span class="h-px w-12 bg-primary/30"></span>
        <span class="text-sm font-bold uppercase tracking-widest">{services.assessmentLabel}</span>
      </div>
    </div>

    <div class="glass-card p-8 rounded-3xl col-span-3 border-primary/40 h-fit">
      <ul class="space-y-2 text-sm mt-6">
        {
          services.assessmentList.map((item) => (
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-secondary text-sm mt-0.5">
                check_circle
              </span>
              <span class="text-slate-600">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="grid lg:grid-cols-6 gap-12 max-w-7xl mx-auto items-center">
    <div class="col-span-3">
      <h3 class="text-4xl font-black tracking-tight mb-6 text-slate-900">
        {services.interventionTitle}
      </h3>
      <p class="text-slate-500 text-lg max-w-md leading-relaxed">
        {services.interventionDescription}
      </p>
      <div class="mt-8 flex items-center gap-4 text-primary">
        <span class="h-px w-12 bg-primary/30"></span>
        <span class="text-sm font-bold uppercase tracking-widest">{services.interventionLabel}</span
        >
      </div>
    </div>

    <div class="glass-card p-8 rounded-3xl col-span-3 border-primary/40">
      <ul class="space-y-2 text-sm mt-6">
        {
          services.interventionList.map((item) => (
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-secondary text-sm mt-0.5">
                check_circle
              </span>
              <span class="text-slate-600">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</div>
