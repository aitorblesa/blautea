---
import { getI18N } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
const cards = i18n.heroCards.items
---

<section class="w-full bg-background-light pb-24 px-6">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 -mt-12">
    <div class="glass-card p-8 rounded-3xl group hover:border-primary/50 transition-colors">
      <div
        class="w-12 h-12 bg-secondary/20 rounded-2xl flex items-center justify-center text-secondary mb-6 group-hover:scale-110 transition-transform"
      >
        <span class="material-symbols-outlined text-3xl">diversity_2</span>
      </div>
      <h3 class="text-xl font-bold mb-3">{cards[0].title}</h3>
      <p class="text-slate-600 text-md leading-relaxed">
        {cards[0].description}
      </p>
    </div>
    <div class="glass-card p-8 rounded-3xl group hover:border-primary/50 transition-colors">
      <div
        class="w-12 h-12 bg-secondary/20 rounded-2xl flex items-center justify-center text-secondary mb-6 group-hover:scale-110 transition-transform"
      >
        <span class="material-symbols-outlined text-3xl">psychology</span>
      </div>
      <h3 class="text-xl font-bold mb-3">{cards[1].title}</h3>
      <p class="text-slate-600 text-md leading-relaxed">
        {cards[1].description}
      </p>
    </div>
    <div class="glass-card p-8 rounded-3xl group hover:border-primary/50 transition-colors">
      <div
        class="w-12 h-12 bg-secondary/20 rounded-2xl flex items-center justify-center text-secondary mb-6 group-hover:scale-110 transition-transform"
      >
        <span class="material-symbols-outlined text-3xl">science</span>
      </div>
      <h3 class="text-xl font-bold mb-3">{cards[2].title}</h3>
      <p class="text-slate-600 text-md leading-relaxed">
        {cards[2].description}
      </p>
    </div>
  </div>
</section>
