---
import { getI18N } from '@/i18n'

const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
---

<footer class="fade-in-section border-slate-200 pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      <div class="col-span-2">
        <div class="flex gap-3 mb-6 items-end">
          <img alt={i18n.header.logoAlt} class="h-16" src="/BlauteaLogo.webp" />
          <button
            id="share-btn"
            class="w-10 h-10 flex items-center justify-center text-slate-400 hover:text-primary transition-colors cursor-pointer"
            aria-label="Compartir"
          >
            <span class="material-symbols-outlined">share</span>
          </button>
        </div>
        <p class="text-slate-500 max-w-sm mb-6 leading-relaxed">
          {i18n.footer.description}
        </p>
      </div>
      <div class="col-span-2">
        <h5 class="font-bold mb-6 text-accent">{i18n.footer.exploreTitle}</h5>
        <ul class="space-y-4 text-slate-500 grid grid-cols-2">
          <li>
            <a
              class="hover:text-primary transition-colors flex items-center gap-2"
              href={`#${i18n.header.servicesRef}`}
            >
              <span class="material-symbols-outlined text-sm">chevron_right</span>{
                i18n.header.services
              }
            </a>
          </li>
          <li>
            <a
              class="hover:text-primary transition-colors flex items-center gap-2"
              href={`#${i18n.header.methodologyRef}`}
            >
              <span class="material-symbols-outlined text-sm">chevron_right</span>{
                i18n.header.methodology
              }
            </a>
          </li>
          <li>
            <a
              class="hover:text-primary transition-colors flex items-center gap-2"
              href={`#${i18n.header.teamRef}`}
            >
              <span class="material-symbols-outlined text-sm">chevron_right</span>{i18n.header.team}
            </a>
          </li>
          <li>
            <a
              class="hover:text-primary transition-colors flex items-center gap-2"
              href={`#${i18n.header.contactRef}`}
            >
              <span class="material-symbols-outlined text-sm">chevron_right</span>{
                i18n.header.contact
              }
            </a>
          </li>
          <li>
            <a
              class="hover:text-primary transition-colors flex items-center gap-2"
              href={`#${i18n.header.faqsRef}`}
            >
              <span class="material-symbols-outlined text-sm">chevron_right</span>{i18n.header.faqs}
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t border-slate-200 text-center text-slate-400 text-sm">
      {i18n.footer.copyright}
    </div>
  </div>
</footer>

<script>
  const btn = document.getElementById('share-btn')

  btn?.addEventListener('click', async () => {
    const shareData = {
      title: document.title,
      text: document.querySelector('meta[name="description"]')?.getAttribute('content') ?? '',
      url: window.location.href,
    }

    if (navigator.share) {
      try {
        await navigator.share(shareData)
      } catch (err) {}
    } else {
      await navigator.clipboard.writeText(window.location.href)
      btn.querySelector('span')!.textContent = 'check'
      setTimeout(() => {
        btn.querySelector('span')!.textContent = 'share'
      }, 2000)
    }
  })
</script>
